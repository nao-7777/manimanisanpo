<%# app/views/characters/index.html.erb %>

<%# --- データの準備 --- %>
<% 
  @all_characters ||= Character.all.order(:id)
  @user_character_ids ||= current_user.user_characters.pluck(:character_id)
%>

<div class="zukan-page-wrapper">
  <div class="zukan-header">
    <h1 class="zukan-title">神様図鑑</h1>
    <div class="zukan-stats text-sm font-bold text-gray-500">
      参拝済み：<span><%= @user_character_ids.count %></span> / <%= @all_characters.count + 1 %>
    </div>
  </div>

  <div class="zukan-grid">
    <%# --- 1. 登録済みのキャラを表示 --- %>
    <% @all_characters.each_with_index do |char, index| %>
      <% is_owned = @user_character_ids.include?(char.id) %>
      
      <%= link_to (is_owned ? character_path(char) : "#"), 
          class: "zukan-card #{is_owned ? 'is-unlocked' : 'is-locked'}" do %>
        
        <span class="zukan-badge"><%= sprintf("%03d", index + 1) %></span>

        <div class="zukan-image-container">
          <% if is_owned %>
            <%= image_tag char.respond_to?(:image_v1) ? char.image_v1 : char.image_path, class: "zukan-img" %>
          <% else %>
            <%= image_tag char.respond_to?(:image_v1) ? char.image_v1 : char.image_path, class: "zukan-img silhouette" %>
            <div class="lock-icon-container text-gray-400 opacity-40">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </div>
          <% end %>
        </div>

        <div class="zukan-info">
          <p class="zukan-name"><%= is_owned ? char.name : "？？？" %></p>
        </div>
      <% end %>
    <% end %>

    <%# --- 2. カミングスーン枠 --- %>
    <div class="zukan-card is-locked">
      <span class="zukan-badge"><%= sprintf("%03d", @all_characters.count + 1) %></span>
      
      <div class="zukan-image-container flex items-center justify-center bg-white">
        <div class="flex flex-col items-center justify-center gap-1 opacity-20">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <span class="text-[8px] font-black tracking-widest">COMING SOON</span>
        </div>
      </div>

      <%# 名前エリア %>
      <div class="zukan-info">
        <p class="zukan-name text-gray-500">？？？</p>
      </div>
    </div>
  </div>
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@700;900&family=Sawarabi+Mincho&display=swap');

.zukan-page-wrapper {
  min-height: 100vh;
  padding-top: 40px;
  padding-bottom: 120px;
  position: relative;
  background: transparent;
  font-family: 'Noto Serif JP', 'Sawarabi Mincho', serif;
}

.zukan-header {
  text-align: center;
  margin-bottom: 35px;
  position: relative;
}

.zukan-header::after {
  content: '';
  position: absolute;
  bottom: -15px;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 2px;
  background: linear-gradient(to right, transparent, #EE8095, transparent);
}

.zukan-title {
  font-size: 1.6rem;
  font-weight: 900;
  color: #38423B;
  margin-bottom: 6px;
  text-shadow: 1px 1px 0 rgba(255,255,255,0.8);
}

.zukan-stats span {
  color: #EE8095;
  font-size: 1.1rem;
}

.zukan-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
  padding: 0 18px;
  max-width: 500px;
  margin: 0 auto;
}

.zukan-card {
  position: relative;
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 12px;
  text-decoration: none;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
}

.zukan-card.is-unlocked {
  border: 1.5px solid #fff;
  box-shadow: 0 8px 25px rgba(101, 199, 164, 0.15);
}

.zukan-image-container {
  position: relative;
  aspect-ratio: 1 / 1;
  background: #fff;
  overflow: hidden;
  display: flex;
  justify-content: center;
}

.zukan-badge {
  position: absolute;
  top: 6px;
  left: 6px;
  background: rgba(56, 66, 59, 0.85);
  color: #F5F5F0;
  font-size: 0.6rem;
  font-weight: bold;
  padding: 1px 6px;
  border-radius: 3px;
  z-index: 20;
}

.zukan-img {
  width: 120%;
  height: 140%;
  object-fit: contain;
  object-position: top center;
  margin-top: 4px;
}

.silhouette {
  filter: brightness(0) opacity(0.08) !important;
}

.lock-icon-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.zukan-info {
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 4px;
  background: rgba(235, 230, 215, 0.8); /* 💡 金宵と同じベージュ */
  border-top: 1px solid rgba(0,0,0,0.05);
  text-align: center;
}

.zukan-name {
  font-weight: 900;
  font-size: 0.75rem;
  margin: 0;
  color: #333;
}
</style>