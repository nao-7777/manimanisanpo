<div class="min-h-screen pt-24 pb-12 flex flex-col items-center justify-center bg-gradient-to-b from-[#ffe2ea] via-[#ffe2ea] via-20% to-[#97DBC1]">
  
  <div class="w-full max-w-md px-4">

    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-lg border border-none bg-white/70 backdrop-blur-sm">
      
      <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">パスワードの再設定</h2>
      
      <p class="text-sm text-gray-500 text-center mb-10 leading-relaxed">
        ご登録のメールアドレスを入力してください。<br>パスワード再設定用のリンクをお送りします。
      </p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%# メールアドレス %>
        <div class="mb-10">
          <%= f.label :email, "メールアドレス", class: "block text-sm font-bold text-gray-600 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com",
              class: "w-full px-5 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder:text-gray-300 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 focus:border-[#65C7A4] shadow-inner" %>
        </div>

        <%# 送信ボタン %>
        <div class="text-center mb-8">
          <%= f.submit "再設定メールを送信", 
              class: "w-full px-10 py-3 text-white font-bold text-lg rounded-full transition-all hover:opacity-90 hover:shadow-lg shadow-md cursor-pointer",
              style: "background-color: #65C7A4;" %>
        </div>

      <% end %>

      <%# 境界線 %>
      <div class="border-t border-gray-200 mb-8"></div>

      <%# 戻るリンク %>
      <div class="text-center">
        <%= link_to "ログイン画面に戻る", new_session_path(resource_name),
            class: "text-sm text-[#65C7A4] font-bold hover:underline" %>
      </div>

    </div>
  </div>
</div>