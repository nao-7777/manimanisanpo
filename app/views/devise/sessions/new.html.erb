<style>
  body { margin: 0; }
  input { font-size: 16px !important; }
  .flash-container {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) translateY(-100%);
    width: 90%;
    z-index: 50;
  }
</style>

<div class="h-[100dvh] w-full flex flex-col bg-gradient-to-b from-[#ffe2ea] via-[#ffe2ea] via-20% to-[#97DBC1] bg-fixed px-6 overflow-hidden">
  
  <%# ヘッダー分の高さを絶対に確保（重なり防止） %>
  <div class="h-16 md:h-20 flex-shrink-0"></div>

  <%# 残りのエリアでカードを中央配置 %>
  <div class="flex-grow flex items-center justify-center py-4">
    <div class="w-full max-w-md max-h-full z-10 relative">

      <div class="flash-container">
        <%= render "devise/shared/flash_messages" %>
      </div>

      <%# カード内の余白を微調整して1画面に収める %>
      <div class="bg-white/70 py-7 px-8 md:px-10 rounded-[2.5rem] shadow-xl backdrop-blur-md overflow-hidden"
           style="background-color: rgba(255, 255, 255, 0.75);">
        
        <h2 class="text-xl font-black text-center text-gray-800 mb-5 tracking-tighter">ログイン</h2>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          
          <div class="mb-4">
            <%= f.label :email, "メールアドレス", class: "block text-[10px] font-bold text-gray-400 mb-1 ml-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com",
                required: true,
                class: "w-full px-4 py-2 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
          </div>

          <div class="mb-5">
            <%= f.label :password, "パスワード", class: "block text-[10px] font-bold text-gray-400 mb-1 ml-1" %>
            <%= f.password_field :password, autocomplete: "current-password", placeholder: "パスワードを入力",
                required: true,
                class: "w-full px-4 py-2 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
          </div>

          <div class="text-center mb-5">
            <%= f.submit "ログインする", 
                class: "w-full max-w-[200px] mx-auto py-2.5 text-white font-black text-base rounded-full transition-all hover:opacity-90 shadow-md cursor-pointer block border-none",
                style: "background-color: #65C7A4;" %>
          </div>
        <% end %>

        <div class="text-center mb-5">
          <%= link_to "パスワードを忘れた場合", new_password_path(resource_name), class: "text-xs text-[#F7A7A2] hover:text-[#f38d87] underline font-bold" %>
        </div>

        <%# --- SNSログイン --- %>
        <div class="relative flex items-center justify-center my-4">
          <div class="flex-grow border-t border-gray-300"></div>
          <span class="flex-shrink mx-4 text-xs font-bold text-gray-500">または</span>
          <div class="flex-grow border-t border-gray-300"></div>
        </div>

        <div class="flex justify-center gap-8 mb-5">
          <%# Googleボタン %>
          <%= button_to user_google_oauth2_omniauth_authorize_path, 
                        data: { turbo: false }, 
                        class: "w-11 h-11 flex items-center justify-center bg-[#65C7A4]/85 rounded-2xl hover:opacity-90 transition-all border-none shadow-sm cursor-pointer" do %>
            <span class="text-white text-xl font-black">G</span>
          <% end %>

          <%# LINEボタン (将来用) %>
          <%= link_to "#", class: "w-11 h-11 flex items-center justify-center bg-[#65C7A4]/85 rounded-2xl hover:opacity-90 transition-all text-decoration-none shadow-sm" do %>
            <span class="text-white text-[10px] font-black leading-none text-center">LINE</span>
          <% end %>

          <%# Xボタン (将来用) %>
          <%= link_to "#", class: "w-11 h-11 flex items-center justify-center bg-[#65C7A4]/85 rounded-2xl hover:opacity-90 transition-all text-decoration-none shadow-sm" do %>
            <span class="text-white text-xl font-black italic">X</span>
          <% end %>
        </div>

        <div class="border-t border-gray-300 my-5"></div>

        <div class="text-center">
          <p class="text-[10px] text-gray-400 font-bold mb-2">初めての方はこちら</p>
          <%= link_to "アカウント作成", new_registration_path(resource_name),
              class: "w-full max-w-[180px] mx-auto py-2 text-[#65C7A4] font-bold text-xs rounded-full border-2 border-[#65C7A4] inline-block transition-all hover:bg-[#65C7A4]/10 text-decoration-none" %>
        </div>

      </div>
    </div>
  </div>
</div>