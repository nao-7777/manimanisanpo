<style>
  body { margin: 0; }
  input { font-size: 16px !important; }
  /* フラッシュメッセージをカードの上に浮かせるためのスタイル */
  .flash-container {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%) translateY(-100%);
    width: 90%;
    z-index: 50;
  }
</style>

<div class="min-h-[100dvh] w-full flex flex-col items-center justify-center bg-gradient-to-b from-[#ffe2ea] via-[#ffe2ea] via-20% to-[#97DBC1] bg-fixed px-6 overflow-hidden">
  
  <div class="w-full max-w-md z-10 mt-20 mb-10 relative">

    <%# --- ここでエラーメッセージ（重複エラーなど）を浮かせる --- %>
    <div class="flash-container">
      <%= render "devise/shared/error_messages", resource: resource %>
    </div>

    <div class="bg-white/70 p-8 md:p-10 rounded-[2.5rem] shadow-xl backdrop-blur-md"
         style="background-color: rgba(255, 255, 255, 0.75);">
      
      <h2 class="text-xl font-black text-center text-gray-800 mb-6 tracking-tighter">アカウント作成</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { data: { turbo: false } }) do |f| %>
        
        <div class="mb-4">
          <%= f.label :email, "メールアドレス", class: "block text-[10px] font-bold text-gray-400 mb-1 ml-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com",
              required: true,
              class: "w-full px-4 py-2.5 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
        </div>

        <div class="mb-4">
          <div class="flex justify-between items-center mb-1 ml-1">
            <%= f.label :password, "パスワード", class: "text-[10px] font-bold text-gray-400" %>
            <% if @minimum_password_length %>
              <span class="text-[9px] text-gray-300 font-normal">(<%= @minimum_password_length %>文字〜)</span>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "パスワードを設定",
              required: true,
              class: "w-full px-4 py-2.5 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
        </div>

        <div class="mb-6">
          <%= f.label :password_confirmation, "確認用", class: "block text-[10px] font-bold text-gray-400 mb-1 ml-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "もう一度入力",
              required: true,
              class: "w-full px-4 py-2.5 border border-gray-200 rounded-xl text-gray-800 placeholder:text-gray-200 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 shadow-inner text-sm transition-all bg-white" %>
        </div>

        <div class="text-center">
          <%= f.submit "アカウント作成", 
              class: "w-full max-w-[200px] mx-auto py-3 text-white font-black text-base rounded-full transition-all hover:opacity-90 shadow-md cursor-pointer block border-none",
              style: "background-color: #65C7A4;" %>
        </div>
      <% end %>

      <div class="border-t border-gray-300 my-6"></div>

      <div class="text-center">
        <p class="text-[10px] text-gray-400 font-bold mb-3">すでに登録済みの方</p>
        <%= link_to "ログインはこちら", new_session_path(resource_name),
            class: "w-full max-w-[180px] mx-auto py-2.5 text-[#65C7A4] font-bold text-xs rounded-full border-2 border-[#65C7A4] inline-block transition-all hover:bg-[#65C7A4]/5 text-decoration-none" %>
      </div>

    </div>
  </div>
</div>