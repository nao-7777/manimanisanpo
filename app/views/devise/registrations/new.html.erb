<div class="min-h-screen pt-24 pb-12 flex flex-col items-center justify-center bg-gradient-to-b from-[#ffe2ea] via-[#ffe2ea] via-20% to-[#97DBC1]">
  
  <div class="w-full max-w-md px-4">

    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-lg border border-none backdrop-blur-sm"
     style="background-color: rgba(255, 255, 255, 0.7);">
      
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-10">アカウント作成</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%# メールアドレス %>
        <div class="mb-6">
          <%= f.label :email, "メールアドレス", class: "block text-sm font-bold text-gray-600 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com",
              class: "w-full px-5 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder:text-gray-300 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 focus:border-[#65C7A4] shadow-inner" %>
        </div>

        <%# パスワード %>
        <div class="mb-6">
          <div class="flex justify-between items-center mb-2">
            <%= f.label :password, "パスワード", class: "text-sm font-bold text-gray-600" %>
            <% if @minimum_password_length %>
              <span class="text-xs text-gray-400 font-normal">(<%= @minimum_password_length %>文字以上)</span>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "パスワードを設定",
              class: "w-full px-5 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder:text-gray-300 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 focus:border-[#65C7A4] shadow-inner" %>
        </div>

        <%# パスワード（確認用） %>
        <div class="mb-8">
          <%= f.label :password_confirmation, "パスワード（確認用）", class: "block text-sm font-bold text-gray-600 mb-2" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "もう一度入力してください",
              class: "w-full px-5 py-3 border border-gray-300 rounded-lg text-gray-800 placeholder:text-gray-300 focus:outline-none focus:ring-2 focus:ring-[#65C7A4]/50 focus:border-[#65C7A4] shadow-inner" %>
        </div>

        <%# 登録するボタン %>
        <div class="text-center mb-6">
          <%= f.submit "アカウント作成", 
              class: "w-full md:w-auto px-10 py-3 text-white font-bold text-lg rounded-full transition-all hover:opacity-90 hover:shadow-lg shadow-md cursor-pointer",
              style: "background-color: #65C7A4;" %>
        </div>

      <% end %>

      <%# 境界線 %>
      <div class="border-t border-gray-200 mb-10 mt-10"></div>

      <%# すでにアカウントをお持ちの方 %>
      <div class="text-center">
        <p class="text-base text-gray-700 font-bold mb-6">すでに登録済みの方</p>
        <%= link_to "ログインはこちら", new_session_path(resource_name),
            class: "px-8 py-3 text-[#65C7A4] font-bold text-lg rounded-full border-2 border-[#65C7A4] inline-block transition-colors hover:bg-[#65C7A4]/10" %>
      </div>

    </div>
  </div>
</div>