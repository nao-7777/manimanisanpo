<% flash.each do |key, value| %>
  <% next if key == "sent_modal" %>
  <div class="mb-6 p-4 text-sm font-bold text-center rounded-[1.5rem] shadow-sm border
    <%= key == 'notice' ? 'bg-blue-50 text-blue-600 border-blue-100' : 'bg-red-50 text-red-600 border-red-100' %>">
    <%= value %>
  </div>
<% end %>