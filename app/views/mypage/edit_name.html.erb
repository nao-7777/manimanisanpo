<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-[100] flex items-center justify-center p-4">
    <%# 背景のオーバーレイ %>
    <%= link_to mypage_path, class: "absolute inset-0 bg-black/20 backdrop-blur-sm" do %><% end %>

    <%# モーダル本体 %>
    <div class="relative bg-white w-full max-w-xs rounded-[2rem] p-8 border-2 border-gray-400 shadow-2xl animate-in fade-in zoom-in duration-200">
      <h2 class="text-xl font-black text-gray-800 mb-6 text-center">名前変更</h2>
      
      <%= form_with model: @user, url: update_mypage_name_path, method: :patch, data: { turbo: false }, class: "space-y-6" do |f| %>
        <div class="bg-[#F0F0F0] rounded-xl border-2 border-gray-300 p-2">
          <%= f.text_field :name, 
              value: "", 
              placeholder: "新しい名前を入力", 
              autofocus: true,
              autocomplete: "off",
              class: "w-full bg-transparent border-none outline-none focus:outline-none focus:ring-0 font-bold text-gray-700" %>
        </div>

        <div class="flex flex-col gap-3">
          <%= f.submit "変更する", class: "w-full bg-white border-2 border-[#65C7A4] text-[#65C7A4] font-black py-2 rounded-xl border-b-4 active:border-b-0 active:translate-y-0.5 shadow-sm" %>
          <%= link_to "閉じる", mypage_path, class: "text-center text-sm font-bold text-gray-400 pt-2" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>