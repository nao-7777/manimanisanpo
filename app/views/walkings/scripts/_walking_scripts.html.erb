<script>
  window.steps = 0;
  let isSensorInitialized = false;

  // 💡 狐のジャンプ：画像(fox-image)だけを上下させる
  window.jumpFox = function() {
    const img = document.getElementById('fox-image');
    if (img) {
      img.style.transform = "translateY(-30px)";
      setTimeout(() => { 
        img.style.transform = "translateY(0)"; 
      }, 200);
    }
  };

  // 💡 セリフ表示：タイマーを完全にリセットして上書きを保証
  window.showFoxTalk = function(text) {
    const bubble = document.getElementById('fox-bubble');
    if (!bubble) return;

    if (window.foxTimer) clearTimeout(window.foxTimer);
    if (window.foxHideTimer) clearTimeout(window.foxHideTimer);

    bubble.innerText = text;
    bubble.style.display = "block";
    
    // アニメーションを一旦切って即座に表示
    bubble.style.transition = "none";
    bubble.style.opacity = "1";
    
    // 次のフレームでアニメーションを戻す
    setTimeout(() => {
      bubble.style.transition = "opacity 0.3s ease";
    }, 50);

    window.foxTimer = setTimeout(() => {
      window.hideFoxBubble();
    }, 8000);
  };

  window.hideFoxBubble = function() {
    const bubble = document.getElementById('fox-bubble');
    if (bubble) { 
      bubble.style.opacity = "0"; 
      window.foxHideTimer = setTimeout(() => { 
        bubble.style.display = "none"; 
      }, 500); 
    }
  };

  window.createParticles = function(el) {
    const rect = el.getBoundingClientRect();
    for (let i = 0; i < 12; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.background = ['#FFD700', '#65C7A4', '#EE8095'][Math.floor(Math.random() * 3)];
      p.style.left = `${rect.left + rect.width / 2}px`;
      p.style.top = `${rect.top + rect.height / 2}px`;
      p.style.setProperty('--dx', `${(Math.random() - 0.5) * 200}px`);
      p.style.setProperty('--dy', `${(Math.random() - 0.5) * 200}px`);
      document.body.appendChild(p);
      setTimeout(() => p.remove(), 600);
    }
  };

  window.addEventListener('click', (e) => {
    if (e.target.closest('#btn-camera-container,#walking-mission-card,#walking-header-container,#btn-album,#btn-map,button,a,.status-badge')) return;
    if (!isSensorInitialized) { isSensorInitialized = true; return; }
    window.steps++;
    if (window.updateStepDisplay) window.updateStepDisplay(window.steps);
  });
</script>
<%= render 'walkings/scripts/tracker' %>