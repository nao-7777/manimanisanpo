<%# ライブラリの読み込み %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
  #walking-map-container {
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100vw; 
    height: 100%; /* 💡 100vhより安定する100%に変更 */
    background: white; 
    /* 💡 ボトムナビより確実に上に来るように数値を引き上げ */
    z-index: 99999; 
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: auto;
    overflow: hidden;
  }
  
  #walking-map-container.is-open { 
    transform: translateY(0%); 
  }

  /* 💡 地図が開いている時だけ、既存のナビゲーションを画面外へ追いやる */
  body:has(#walking-map-container.is-open) .bottom-nav,
  body:has(#walking-map-container.is-open) .walking-footer,
  body:has(#walking-map-container.is-open) footer {
    display: none !important;
  }

  .current-location-dot {
    background-color: #007AFF; 
    border: 3px solid white; 
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(0,122,255,0.4);
  }

  /* 地図自体のサイズを確保 */
  #map {
    width: 100%;
    height: 100%;
    background: #f8f8f8;
  }
</style>

<div id="walking-map-container">
  <button onclick="toggleMap()" style="position: absolute; top: 30px; right: 20px; z-index: 100000; background: white; border: none; border-radius: 50%; width: 45px; height: 45px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; cursor: pointer;">
    <i class="bi bi-x-lg" style="font-size: 20px; color: #555;"></i>
  </button>
  <div id="map"></div>
</div>

<script>
  let map, userMarker;

  function initMap() {
    if (map) return;

    map = L.map('map', { 
      zoomControl: false,
      tap: false 
    }).setView([35.681236, 139.767125], 16);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { 
      attribution: '© OpenStreetMap' 
    }).addTo(map);

    if (navigator.geolocation) {
      navigator.geolocation.watchPosition((position) => {
        const latlng = [position.coords.latitude, position.coords.longitude];
        if (!userMarker) {
          userMarker = L.marker(latlng, { 
            icon: L.divIcon({ className: 'current-location-dot', iconSize: [18, 18] }) 
          }).addTo(map);
          map.setView(latlng);
        } else { 
          userMarker.setLatLng(latlng); 
        }
      }, (err) => console.warn(err), { enableHighAccuracy: true });
    }
  }

  document.addEventListener('turbo:load', initMap);
  if (!map) { initMap(); }

  function toggleMap() {
    const container = document.getElementById('walking-map-container');
    const isOpen = container.classList.toggle('is-open');
    
    // 💡 地図が開いたとき、背後のスクロールを止める（任意）
    document.body.style.overflow = isOpen ? 'hidden' : '';

    if (isOpen) {
      setTimeout(() => {
        if (map) { map.invalidateSize(true); }
      }, 100); 
      
      setTimeout(() => {
        if (map) { map.invalidateSize(true); }
      }, 450);
    }
  }
</script>