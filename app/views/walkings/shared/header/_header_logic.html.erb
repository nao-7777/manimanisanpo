<% content_for :no_nav, true %>
<% content_for :is_walking_mode, true %>

<div 
  data-controller="walking-mode"
  data-walking-mode-walk-id-value="<%= @walk.id %>"
  data-walking-mode-initial-steps-value="<%= @walk.steps || 0 %>"
  data-walking-mode-initial-duration-value="<%= @walk.duration || 0 %>"
  style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 100; overflow: hidden; pointer-events: none;">
  
  <%# --- ヘッダー --- %>
  <%= render 'walkings/shared/header/walking_header' %>
  
  <%# --- お題カード --- %>
  <%= render 'walkings/shared/missions/walking_mission' %>

  <%# --- キャラクター表示 --- %>
  <%= render 'walkings/shared/walking_character' %>
</div>

<%# --- お散歩モードのボトムナビ --- %>
<div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9999; pointer-events: none;">
  <%= render 'walkings/shared/walking_footer' %>
</div>

<script>
  (function() {
    const initializeWalkHeader = () => {
      const walkId = <%= @walk.id %>;
      const storageKey = `walk_data_${walkId}`;
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
      
      const savedData = JSON.parse(localStorage.getItem(storageKey) || '{}');
      let currentSteps = savedData.steps !== undefined ? savedData.steps : <%= @walk.steps || 0 %>;
      let totalSeconds = savedData.duration !== undefined ? savedData.duration : <%= @walk.duration || 0 %>;

      window.steps = currentSteps;

      const timerEl = document.getElementById('display-timer');
      const stepsEl = document.getElementById('display-steps');

      function reflectDisplay() {
        if (stepsEl) stepsEl.innerText = currentSteps.toLocaleString();
        if (timerEl) {
          const mins = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
          const secs = (totalSeconds % 60).toString().padStart(2, '0');
          timerEl.innerText = `${mins}:${secs}`;
        }
      }

      reflectDisplay();

      window.updateStepDisplay = (count) => {
        currentSteps = count;
        window.steps = count;
        reflectDisplay();
        localStorage.setItem(storageKey, JSON.stringify({ steps: currentSteps, duration: totalSeconds }));
      };

      function tick() {
        totalSeconds++;
        reflectDisplay();
        localStorage.setItem(storageKey, JSON.stringify({ steps: currentSteps, duration: totalSeconds }));
      }
      const timerInterval = setInterval(tick, 1000);

      // --- センサー系 ---
      const ACCEL_THRESHOLD = 12; 
      let lastAccel = 0;
      let isWalking = false;

      window.handleMotion = function(event) {
        const accel = event.accelerationIncludingGravity;
        if (!accel) return;
        const totalAccel = Math.sqrt(accel.x**2 + accel.y**2 + accel.z**2);
        const delta = Math.abs(totalAccel - lastAccel);
        if (delta > ACCEL_THRESHOLD && !isWalking) {
          isWalking = true;
          window.updateStepDisplay(currentSteps + 1);
          if (typeof window.jumpFox === "function") window.jumpFox();
          setTimeout(() => { isWalking = false; }, 300);
        }
        lastAccel = totalAccel;
      };

      window.requestSensorPermission = async function() {
        if (typeof DeviceMotionEvent !== 'undefined' && typeof DeviceMotionEvent.requestPermission === 'function') {
          try {
            const response = await DeviceMotionEvent.requestPermission();
            if (response === 'granted') window.addEventListener('devicemotion', window.handleMotion);
          } catch (e) { console.error(e); }
        } else {
          window.addEventListener('devicemotion', window.handleMotion);
        }
      };

      // 【修正箇所】タップで歩数を増やすのをやめ、最初のタップでセンサーを起動するだけに
      const startSensorOnce = () => {
        window.requestSensorPermission();
        document.removeEventListener('click', startSensorOnce);
      };
      document.addEventListener('click', startSensorOnce);

      const autoSaveInterval = setInterval(async () => {
        try {
          await fetch(`/walkings/${walkId}/save_progress`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' },
            body: JSON.stringify({ walking: { steps: currentSteps, duration: totalSeconds } })
          });
        } catch (e) {}
      }, 10000);

      // ボタンの取得とイベント登録
      const stopBtn = document.getElementById('btn-finish-walking-trigger');
      if (stopBtn) {
        stopBtn.onclick = async (e) => {
          e.preventDefault();
          if (!confirm('お散歩を終了して記録を保存しますか？')) return;
          try {
            const res = await fetch(`/walkings/${walkId}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' },
              body: JSON.stringify({ steps: currentSteps, duration: totalSeconds })
            });
            if (res.ok) {
              localStorage.removeItem(storageKey);
              const data = await res.json();
              window.location.href = data.redirect_url;
            }
          } catch (err) {}
        };
      }

      // ページを離れるときにタイマーを掃除
      document.addEventListener("turbo:before-visit", () => {
        clearInterval(timerInterval);
        clearInterval(autoSaveInterval);
      }, { once: true });
    };

    document.addEventListener('turbo:load', initializeWalkHeader);
  })();
</script>