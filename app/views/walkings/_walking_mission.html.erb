<%# 
  ================================================================
  MISSION CARD: [お題表示 & クリア処理]
  ================================================================
%>
<style>
  #walking-mission-card {
    position: absolute; top: 180px; left: 50%; width: 88%; max-width: 380px; 
    transform: translateX(-50%); background: rgba(255, 250, 252, 0.95); 
    backdrop-filter: blur(15px); padding: 30px 25px 20px 25px; 
    border-radius: 2.5rem; box-shadow: 0 10px 40px rgba(101, 199, 164, 0.15); 
    pointer-events: auto; z-index: 50;
  }
  #photo-preview-container {
    display: none; position: absolute; top: 215px; left: 15px; 
    width: 90px; height: 90px; background: white; padding: 6px; 
    border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.15); 
    transform: rotate(-10deg); z-index: 110;
  }
</style>

<div id="walking-mission-card">
  <div id="photo-preview-container">
    <img id="photo-preview" src="" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
  </div>
  
  <div style="text-align: center;">
    <div style="font-size: 1.4rem; font-weight: 900; color: #EE8095; margin-bottom: 15px;">お題</div>
    <div id="mission-text" data-mission-id="<%= @current_mission&.id %>" style="font-weight: 800; color: #555; font-size: 1.2rem; margin-bottom: 20px; min-height: 3em; display: flex; align-items: center; justify-content: center; text-align: center;">
      <%= (@current_mission&.title || "写真を撮ってクリアしよう！").html_safe %>
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
      <button onclick="skipMission(event)" style="flex: 0 0 80px; height: 35px; background: white; color: #EE8095; border: 3px solid #EE8095; border-radius: 99px; font-weight: 800; font-size: 12px; cursor: pointer;">SKIP</button>
      <button id="btn-complete" class="btn-mission-clear" onclick="completeMission(event)" style="flex: 0 0 120px; height: 45px; background: #65C7A4; color: white; border: 3px solid white; border-radius: 99px; font-weight: 900; font-size: 16px; cursor: pointer;">クリア！</button>
    </div>
  </div>
</div>

<input type="file" id="camera-input" accept="image/*" capture="environment" style="display: none;" onchange="previewImage(this)">

<script>
  // 写真プレビュー
  window.previewImage = function(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('photo-preview').src = e.target.result;
        document.getElementById('photo-preview-container').style.display = 'block';
        if (window.showFoxTalk) showFoxTalk("いい写真だね！");
      }
      reader.readAsDataURL(input.files[0]);
    }
  };

  // ミッション完了処理
  window.completeMission = async function(event) {
    const btn = event.currentTarget;
    if (btn.disabled) return;
    btn.disabled = true;

    const missionTarget = document.getElementById('mission-text');
    const fileInput = document.getElementById('camera-input');
    
    // 💡 1. 画像アップロードを先に完了させる
    if (fileInput.files && fileInput.files[0] && missionTarget.dataset.missionId) {
      const formData = new FormData();
      formData.append('image', fileInput.files[0]);
      formData.append('mission_id', missionTarget.dataset.missionId);
      const token = document.querySelector('meta[name="csrf-token"]').content;
      
      try {
        const res = await fetch('/walkings/upload_image', {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'X-CSRF-Token': token },
          body: formData
        });
        
        const data = await res.json();
        
        // 💡 2. サーバーから返ってきたURLを即座にアルバムに反映
        if (data.image_url && window.addPhotoToAlbum) {
          window.addPhotoToAlbum(data.image_url);
        }
      } catch (e) {
        console.error("Upload failed:", e);
      }
    }

    // 💡 3. エフェクトと次のお題取得
    if (window.createParticles) window.createParticles(btn);
    if (window.jumpFox) window.jumpFox();
    
    const nextData = await fetchNextMission();
    
    setTimeout(() => {
      btn.disabled = false;
      if (nextData && missionTarget) {
        missionTarget.innerHTML = nextData.title;
        missionTarget.dataset.missionId = nextData.id;
      }
      if (window.showFoxTalk) showFoxTalk("おめでとう！クリアだね！");
      
      // プレビュー消去
      document.getElementById('photo-preview-container').style.display = 'none';
      fileInput.value = "";
    }, 400);
  };

  async function fetchNextMission() {
    try {
      const response = await fetch('/walkings/random_mission', { 
        headers: { 'Accept': 'application/json' }, 
        cache: 'no-store' 
      });
      return await response.json();
    } catch (e) { return null; }
  }

  window.skipMission = async function(event) {
    const nextData = await fetchNextMission();
    const missionTarget = document.getElementById('mission-text');
    if (nextData && missionTarget) {
      missionTarget.innerHTML = nextData.title;
      missionTarget.dataset.missionId = nextData.id;
    }
    if (window.showFoxTalk) showFoxTalk("了解！次にするね！");
    document.getElementById('photo-preview-container').style.display = 'none';
  };
</script>