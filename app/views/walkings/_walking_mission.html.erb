<%# --- 3. お題カード --- %>
<div style="position: absolute; top: 180px; left: 50%; width: 88%; max-width: 380px; transform: translateX(-50%); background: rgba(255, 250, 252, 0.95); backdrop-filter: blur(15px); padding: 30px 25px 20px 25px; border-radius: 2.5rem; box-shadow: 0 10px 40px rgba(101, 199, 164, 0.15); pointer-events: auto; z-index: 50;">
  
  <%# 撮影した写真のプレビュー %>
  <div id="photo-preview-container" style="display: none; position: absolute; top: 215px; left: 15px; width: 90px; height: 90px; background: white; padding: 6px; border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.15); transform: rotate(-10deg); z-index: 110;">
    <img id="photo-preview" src="" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
  </div>

  <div style="position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%); width: 0; height: 0; border-left: 20px solid transparent; border-right: 20px solid transparent; border-top: 20px solid rgba(255, 250, 252, 0.95);"></div>
  
  <div style="text-align: center;">
    <div style="font-size: 1.4rem; font-weight: 900; color: #EE8095; margin-bottom: 15px;">お題</div>
    
    <div id="mission-text"
         data-mission-id="<%= @current_mission&.id %>"
         style="font-weight: 800; color: #555; font-size: 1.2rem; margin-bottom: 20px; min-height: 3em; display: flex; align-items: center; justify-content: center;">
      <%= @current_mission&.title || "赤いポストを見つけて写真を撮ろう！" %>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
      <button onclick="skipMission(event)" style="flex: 0 0 80px; height: 35px; background: white; color: #EE8095; border: 3px solid #EE8095; border-radius: 99px; font-weight: 800; font-size: 12px; cursor: pointer; transition: transform 0.1s;">
        SKIP
      </button>
      
      <%# 💡 クリックイベント %>
      <button onclick="completeMission(event)" style="flex: 0 0 120px; height: 45px; background: #65C7A4; color: white; border: 3px solid white; border-radius: 99px; font-weight: 900; font-size: 16px; cursor: pointer;">クリア！</button>
    </div>
  </div>
</div>

<%# 端末のカメラを直接起動する隠し要素 %>
<input type="file" id="camera-input" accept="image/*" capture="environment" style="display: none;" onchange="previewImage(this)">