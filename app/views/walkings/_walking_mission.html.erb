<style>
  .btn-mission-clear { transition: transform 0.1s; user-select: none; }
  .btn-mission-clear:active { transform: scale(0.9); }

  #walking-mission-card {
    position: fixed; 
    top: 200px; 
    left: 50%; 
    width: 88%; 
    max-width: 380px; 
    transform: translateX(-50%); 
    background: rgba(255, 255, 252, 0.97); 
    backdrop-filter: blur(10px); 
    padding: 30px 25px 20px 25px; 
    border-radius: 2.5rem; 
    box-shadow: 0 15px 40px rgba(60, 100, 80, 0.15); 
    border: 2px solid #ffffff;
    pointer-events: auto; 
    z-index: 100;
  }

  #photo-preview-container {
    display: none; position: absolute; top: 215px; left: 15px; 
    width: 90px; height: 90px; background: white; padding: 6px; 
    border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.15); 
    transform: rotate(-10deg); z-index: 110;
  }
  .particle {
    position: fixed; width: 10px; height: 10px; border-radius: 50%; 
    pointer-events: none; z-index: 9999; animation: particle-burst 0.6s ease-out forwards;
  }
  @keyframes particle-burst {
    0% { transform: translate(0, 0) scale(1); opacity: 1; }
    100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
  }
</style>

<div id="walking-mission-card">
  <div id="photo-preview-container">
    <img id="photo-preview" src="" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
  </div>
  
  <div style="text-align: center;">
    <div style="font-size: 1.4rem; font-weight: 900; color: #EE8095; margin-bottom: 15px;">お題</div>
    <div id="mission-text" 
         data-mission-id="<%= @current_mission&.id %>" 
         style="font-weight: 800; color: #555; font-size: 1.2rem; margin-bottom: 20px; min-height: 3em; display: flex; align-items: center; justify-content: center; text-align: center;">
      <%= (@current_mission&.title || "写真を撮ってクリアしよう！").html_safe %>
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
      <button type="button" onclick="skipMission(event)" style="flex: 0 0 80px; height: 35px; background: white; color: #EE8095; border: 3px solid #EE8095; border-radius: 99px; font-weight: 800; font-size: 12px; cursor: pointer;">SKIP</button>
      <button type="button" id="btn-complete" class="btn-mission-clear" onclick="completeMission(event)" style="flex: 0 0 120px; height: 45px; background: #65C7A4; color: white; border: 3px solid white; border-radius: 99px; font-weight: 900; font-size: 16px; cursor: pointer;">クリア！</button>
    </div>
  </div>
</div>

<input type="file" id="camera-input" accept="image/*" capture="environment" style="display: none;" onchange="previewImage(this)">

<script>
  let isFetchingMission = false;

  // 💡 セリフのバリエーション定義
  const foxQuotes = {
    clear: ["いい調子だ。新しい景色を探しにいこうか", "ふふ、やるじゃないか", "見事だ。褒めてやろう", "ふむ。お前といると退屈しないな。","良い収穫だ。次はどうする？"],
    skip: ["別の縁を探すか。いいだろう", "ふふ、お前の気まぐれに付き合おう", "焦らなくていい。散歩は道草が肝心だ", "承知した。次はどこへ行く？"]
  };
  const getQuote = (type) => foxQuotes[type][Math.floor(Math.random() * foxQuotes[type].length)];

  document.addEventListener("DOMContentLoaded", () => {
    const mt = document.getElementById('mission-text');
    const cid = mt.dataset.missionId;
    if (!cid || cid === "" || cid === "null" || cid === "undefined") {
      skipMission();
    }
  });

  async function fetchNewMission() {
    if (isFetchingMission) return null;
    isFetchingMission = true;
    try {
      const res = await fetch(`/walkings/random_mission?t=${Date.now()}`, { 
        headers: { 'Accept': 'application/json' } 
      });
      if (!res.ok) throw new Error('Fetch failed');
      return await res.json();
    } catch (e) { 
      console.error("Fetch Error:", e);
      return null; 
    } finally {
      isFetchingMission = false;
    }
  }

  window.createParticles = function(el) {
    const rect = el.getBoundingClientRect();
    for (let i = 0; i < 15; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.background = ['#FFD700', '#65C7A4', '#EE8095'][Math.floor(Math.random() * 3)];
      p.style.left = (rect.left + rect.width / 2) + 'px';
      p.style.top = (rect.top + rect.height / 2) + 'px';
      p.style.setProperty('--dx', (Math.random() - 0.5) * 200 + 'px');
      p.style.setProperty('--dy', (Math.random() - 0.5) * 200 + 'px');
      document.body.appendChild(p);
      setTimeout(() => p.remove(), 600);
    }
  };

  window.jumpFox = function() {
    const img = document.getElementById('fox-image');
    if (img) {
      img.style.transform = "translateY(-30px)";
      setTimeout(() => { img.style.transform = "translateY(0)"; }, 200);
    }
  };

  window.previewImage = function(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        document.getElementById('photo-preview').src = e.target.result;
        document.getElementById('photo-preview-container').style.display = 'block';
      }
      reader.readAsDataURL(input.files[0]);
    }
  };

  window.completeMission = async function(event) {
    if (event) event.preventDefault();
    const btn = document.getElementById('btn-complete');
    if (btn.dataset.loading === "true") return;

    const mt = document.getElementById('mission-text');
    const mid = mt.dataset.missionId;

    if (!mid || mid === "null" || mid === "" || mid === "undefined") {
       await skipMission();
       return;
    }

    btn.dataset.loading = "true";
    window.createParticles(btn);
    window.jumpFox();

    const walkId = document.querySelector('[data-walking-timer-walk-id-value]')?.dataset.walkingTimerWalkIdValue || "<%= @walk&.id %>";
    const token = document.querySelector('meta[name="csrf-token"]').content;

    const formData = new FormData();
    formData.append('mission_id', mid);

    let url = `/walkings/${walkId}/complete_mission`;
    let method = 'PATCH';

    const fileInput = document.getElementById('camera-input');
    if (fileInput.files && fileInput.files[0]) {
      formData.append('image', fileInput.files[0]);
      url = `/walkings/${walkId}/upload_image`;
      method = 'POST';
    }

    try {
      const res = await fetch(url, {
        method: method,
        headers: { 'Accept': 'application/json', 'X-CSRF-Token': token },
        body: formData
      });
      const data = await res.json();
      if (data.status === 'success' || data.image_url) {
        if (data.image_url && window.addPhotoToAlbum) {
          window.addPhotoToAlbum(data.image_url, mt.innerText);
        }
        setTimeout(() => {
          if (data.next_mission) {
            mt.innerHTML = data.next_mission.title;
            mt.dataset.missionId = data.next_mission.id;
          }
          btn.dataset.loading = "false";
          document.getElementById('photo-preview-container').style.display = 'none';
          fileInput.value = "";
          // 💡 クリア時のランダムセリフ
          if (window.showFoxTalk) showFoxTalk(getQuote('clear'));
        }, 400);
      }
    } catch (e) { 
      console.error("Complete Error:", e);
      btn.dataset.loading = "false";
    }
  };

  window.skipMission = async function(event) {
    if (event) event.preventDefault();
    const data = await fetchNewMission();
    const mt = document.getElementById('mission-text');
    if (data && mt) {
      mt.innerHTML = data.title || "写真を撮ってクリアしよう！";
      mt.dataset.missionId = data.id;
      // 💡 スキップ時のランダムセリフ
      if (window.showFoxTalk) showFoxTalk(getQuote('skip'));
    }
    document.getElementById('photo-preview-container').style.display = 'none';
  };
</script>