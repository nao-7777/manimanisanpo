<%# 
  ================================================================
  FOOTER & ALBUM: [ボトムナビ・アルバム画面 - キャプション付き]
  ================================================================
%>

<%# 1. ボトムナビ本体 %>
<div id="walking-footer-container" style="position: fixed; bottom: 35px; left: 50%; width: 92%; max-width: 420px; height: 95px; transform: translateX(-50%); pointer-events: none; z-index: 9999;">
  <div style="width: 100%; height: 100%; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(20px); border-radius: 4rem; border: 2px solid white; display: flex; align-items: center; justify-content: space-between; padding: 0 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); pointer-events: auto;">
    <div id="btn-album" onclick="toggleAlbum()" style="width: 65px; height: 65px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;">
      <i class="bi bi-image" style="font-size: 28px; color: #65C7A4;"></i>
    </div>
    <div id="btn-map" onclick="toggleMap()" style="width: 65px; height: 65px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;">
      <i class="bi bi-map" style="font-size: 28px; color: #65C7A4;"></i>
    </div>
  </div>

  <div id="btn-camera-container" style="position: absolute; top: -45px; left: 50%; width: 120px; height: 120px; transform: translateX(-50%); z-index: 10000; pointer-events: auto;">
    <div onclick="openCamera()" style="width: 100%; height: 100%; background: white; border-radius: 50%; padding: 10px; box-shadow: 0 12px 25px rgba(0,0,0,0.15); display: flex; align-items: center; justify-content: center; cursor: pointer;">
      <div style="width: 100%; height: 100%; background: #65C7A4; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
        <i class="bi bi-camera-fill" style="font-size: 48px; color: white;"></i>
      </div>
    </div>
  </div>
</div>

<%# 2. アルバムオーバーレイ %>
<div id="album-overlay" style="position: fixed; top: 100%; left: 0; width: 100%; height: 100%; background: #fffafc; z-index: 10001; transition: top 0.4s cubic-bezier(0.4, 0, 0.2, 1); overflow-y: auto; pointer-events: auto;">
  <div style="position: sticky; top: 0; background: #fffafc; padding: 20px 20px 10px; z-index: 10; display: flex; align-items: center;">
    <div style="flex: 1;"></div>
    <h2 style="font-size: 1.6rem; font-weight: 900; color: #EE8095; margin: 0; letter-spacing: 1px; text-align: center;">お散歩アルバム</h2>
    <div style="flex: 1; text-align: right;">
      <div onclick="toggleAlbum()" style="cursor: pointer; display: inline-block;">
        <i class="bi bi-x-circle-fill" style="font-size: 32px; color: #EE8095;"></i>
      </div>
    </div>
  </div>

  <div id="album-grid" style="padding: 20px 25px 100px; display: grid; grid-template-columns: 1fr 1fr; gap: 25px 20px;">
    <%# 💡 修正：Mission.all ではなく、コントローラーの @captured_missions を使用する %>
    <% if @captured_missions && @captured_missions.any? %>
      <% @captured_missions.each_with_index do |m, i| %>
        <% if m.image.attached? %>
          <div class="album-item" style="width: 100%; background: white; padding: 8px 8px 15px 8px; border-radius: 4px; box-shadow: 0 8px 20px rgba(0,0,0,0.1); transform: rotate(<%= i.even? ? '-4' : '4' %>deg);">
            <div style="width: 100%; aspect-ratio: 1; overflow: hidden; border-radius: 2px; margin-bottom: 8px;">
              <%= image_tag m.image, style: "width:100%; height:100%; object-fit:cover;" %>
            </div>
            <div style="font-size: 11px; font-weight: 800; color: #777; text-align: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; font-family: sans-serif;">
              <%= m.title %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>

<script>
  window.toggleAlbum = function() {
    const album = document.getElementById('album-overlay');
    if (album) {
      const isHidden = (album.style.top === '100%' || album.style.top === '');
      album.style.top = isHidden ? '0px' : '100%';
    }
  };

  window.openCamera = function() {
    const input = document.getElementById('camera-input');
    if (input) input.click();
  };

  window.addPhotoToAlbum = function(imageUrl, title) {
    const grid = document.getElementById('album-grid');
    if (!grid) return;

    const newBox = document.createElement('div');
    const rotate = grid.children.length % 2 === 0 ? '-4' : '4';
    
    newBox.className = "album-item";
    newBox.style.cssText = `
      width: 100%; background: white; padding: 8px 8px 15px 8px; 
      border-radius: 4px; box-shadow: 0 8px 20px rgba(0,0,0,0.1); 
      transform: rotate(${rotate}deg); opacity: 0; transition: opacity 0.6s ease-out;
    `;
    
    newBox.innerHTML = `
      <div style="width: 100%; aspect-ratio: 1; overflow: hidden; border-radius: 2px; margin-bottom: 8px;">
        <img src="${imageUrl}" style="width:100%; height:100%; object-fit:cover;">
      </div>
      <div style="font-size: 11px; font-weight: 800; color: #777; text-align: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">
        ${title || 'お散歩の思い出'}
      </div>
    `;
    
    grid.insertBefore(newBox, grid.firstChild);

    setTimeout(() => {
      newBox.style.opacity = "1";
    }, 100);
  };

  window.toggleMap = function() {
    const container = document.getElementById('walking-map-container');
    if (container) {
      container.classList.toggle('is-open');
      if (container.classList.contains('is-open') && typeof map !== 'undefined') {
        setTimeout(() => { map.invalidateSize(); }, 400);
      }
    }
  };
</script>