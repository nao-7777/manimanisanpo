<% content_for :no_nav, true %>

<div class="fixed inset-0 w-full h-[100dvh] flex flex-col items-center justify-center p-4 overflow-hidden">
  
  <div class="relative z-10 flex flex-col items-center animate-fade-in w-full max-w-lg">
    
    <%# --- キャラエリア --- %>
    <div class="w-full h-[480px] md:h-[600px] flex items-center justify-center animate-float">
      <%= image_tag "characters/koyoi_v1.png", class: "w-full h-full object-contain" %>
    </div>

    <%# --- セリフカード --- %>
    <div id="story-card" class="relative w-full max-w-[440px] cursor-pointer -mt-4 md:-mt-6" onclick="window.nextDialogue()">
      <div class="w-full bg-white/40 backdrop-blur-xl rounded-[2.5rem] px-6 py-8 md:px-10 md:py-12 shadow-[0_10px_40px_rgba(0,0,0,0.08)] border border-white/60 transition-all active:scale-95 active:bg-white/50">
        
        <div id="dialogue-text" 
             class="text-gray-800 leading-relaxed font-black text-lg md:text-xl text-center flex items-center justify-center min-h-[100px]"
             style="letter-spacing: -0.02em; backface-visibility: hidden; transform: translateZ(0);">
          ……驚かせてしまったか。ふふ、<br class='md:hidden'>いきなり目の前に現れたら<br class='md:hidden'>無理もない。
        </div>

        <div class="absolute bottom-6 right-8 flex items-center gap-1 text-[#2E7D32] font-black animate-bounce-x pointer-events-none">
          <span class="text-[10px] opacity-80 tracking-widest">NEXT</span>
          <span class="text-xl">≫</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hidden">
    <%= form_with url: finish_story_path, method: :patch, id: 'finish-form', local: true do %>
    <% end %>
  </div>
</div>

<script>
  (function() {
    const dialogues = [
      "……驚かせてしまったか。ふふ、<br class='md:hidden'>いきなり目の前に現れたら<br class='md:hidden'>無理もない。",
      "俺の名は金宵（こよい）。<br class='md:hidden'>一応、この土地を守る神<br class='md:hidden'>……だったんだがな。",
      "今は力を失って、こんな<br class='md:hidden'>ちんまりした姿になってしまった。<br class='md:hidden'>……困ったもんだ。",
      "だが、お前の魂を見て<br class='md:hidden'>ピンときたんだ。お前なら、<br class='md:hidden'>俺を助けてくれそうだとな。",
      "お前の散歩に、俺も一緒に<br class='md:hidden'>連れていってくれないか？"
      ];

    let currentIndex = 0;
    let isWaiting = false;

    window.nextDialogue = function() {
      if (isWaiting) return;
      const textElement = document.getElementById("dialogue-text");
      const finishForm = document.getElementById("finish-form");
      if (!textElement) return;

      isWaiting = true;
      textElement.style.opacity = 0;
      textElement.style.visibility = "hidden";

      setTimeout(() => {
        textElement.innerHTML = ""; 
        setTimeout(() => {
          currentIndex++;
          if (currentIndex < dialogues.length) {
            textElement.innerHTML = dialogues[currentIndex];
            textElement.style.visibility = "visible";
            textElement.style.opacity = 1;
            isWaiting = false;
          } else if (currentIndex === dialogues.length) {
            textElement.innerHTML = "……ありがとう。お前の見せる<br class='md:hidden'>景色、楽しみにしているぞ。";
            textElement.style.visibility = "visible";
            textElement.style.opacity = 1;
            isWaiting = false;
          } else {
            if (finishForm) finishForm.submit();
          }
        }, 20); 
      }, 200); 
    };

    document.addEventListener("turbo:load", () => { 
      currentIndex = 0;
      isWaiting = false;
    });
  })();
</script>

<style>
  #dialogue-text { transition: opacity 0.4s ease-in-out; }

  /* フェード切り替え */
  #dialogue-text { transition: opacity 0.2s ease-in-out; }

  /* NEXTマークの横揺れ */
  @keyframes bounceX {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(5px); }
  }
  .animate-bounce-x { animation: bounceX 0.8s infinite; }

  /* ふわふわ浮遊 */
  @keyframes float {
    0% { transform: translateY(0px); }
    100% { transform: translateY(-12px); }
  }
  .animate-float { animation: float 2.5s ease-in-out infinite alternate; }

  /* 画面全体の登場アニメーション */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fadeIn 1s cubic-bezier(0.22, 1, 0.36, 1); }
</style>