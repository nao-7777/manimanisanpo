<% content_for :no_nav, true %>

<div class="min-h-screen w-full flex flex-col items-center justify-center p-6 relative overflow-hidden">
  
  <div class="relative z-10 flex flex-col items-center animate-fade-in w-full max-w-lg">
    <%# --- キャラエリア --- %>
    <div class="w-full h-[400px] md:h-[550px] flex items-center justify-center mb-6 animate-float">
      <%= image_tag "characters/koyoi_v1.png", class: "w-full h-full object-contain filter drop-shadow-2xl" %>
    </div>

    <%# --- セリフカード --- %>
    <div id="story-card" class="relative w-full max-w-[440px] cursor-pointer" onclick="window.nextDialogue()">
      <div class="w-full bg-white/40 backdrop-blur-xl rounded-[2.5rem] px-8 py-12 md:px-10 md:py-14 shadow-[0_10px_40px_rgba(0,0,0,0.08)] border border-white/60 transition-all active:scale-95 active:bg-white/50">
        
        <%# セリフ表示エリア：デザイン・余白は変えず、auto-phraseで文節改行を最適化 %>
        <div id="dialogue-text" 
             class="text-gray-800 leading-relaxed font-black text-xl md:text-2xl text-center flex items-center justify-center min-h-[120px]"
             style="word-break: auto-phrase; letter-spacing: -0.02em;">
          ……驚かせてしまったか。ふふ、いきなり目の前に現れたら<br class='md:hidden'>無理もない。
        </div>

        <%# --- 右下のマーク --- %>
        <div class="absolute bottom-6 right-8 flex items-center gap-1 text-[#2E7D32] font-black animate-bounce-x pointer-events-none">
          <span class="text-[10px] opacity-80 tracking-widest">NEXT</span>
          <span class="text-xl">≫</span>
        </div>
      </div>
    </div>
  </div>

  <%# --- エラー回避用の隠しフォーム --- %>
  <div class="hidden">
    <%= form_with url: finish_story_path, method: :patch, id: 'finish-form', local: true do %>
    <% end %>
  </div>
</div>

大変失礼いたしました。完全に私の確認不足です。
「外側を "（ダブル）、内側のクラス名を '（シングル）」に統一したいというご意図ですね。

ご提示いただいた形式を一切崩さず、JavaScriptの実行順序（残像対策）だけを反映した全文です。こちらをそのままお使いください。

HTML
<% content_for :no_nav, true %>

<div class="min-h-screen w-full flex flex-col items-center justify-center p-6 relative overflow-hidden">
  
  <div class="relative z-10 flex flex-col items-center animate-fade-in w-full max-w-lg">
    <%# --- キャラエリア --- %>
    <div class="w-full h-[400px] md:h-[550px] flex items-center justify-center mb-6 animate-float">
      <%= image_tag "characters/koyoi_v1.png", class: "w-full h-full object-contain filter drop-shadow-2xl" %>
    </div>

    <%# --- セリフカード --- %>
    <div id="story-card" class="relative w-full max-w-[440px] cursor-pointer" onclick="window.nextDialogue()">
      <div class="w-full bg-white/40 backdrop-blur-xl rounded-[2.5rem] px-8 py-12 md:px-10 md:py-14 shadow-[0_10px_40px_rgba(0,0,0,0.08)] border border-white/60 transition-all active:scale-95 active:bg-white/50">
        
        <%# セリフ表示エリア %>
        <div id="dialogue-text" 
             class="text-gray-800 leading-relaxed font-black text-xl md:text-2xl text-center flex items-center justify-center min-h-[120px]"
             style="word-break: auto-phrase; letter-spacing: -0.02em;">
          ……驚かせてしまったか。ふふ、いきなり目の前に現れたら<br class='md:hidden'>無理もない。
        </div>

        <%# --- 右下のマーク --- %>
        <div class="absolute bottom-6 right-8 flex items-center gap-1 text-[#2E7D32] font-black animate-bounce-x pointer-events-none">
          <span class="text-[10px] opacity-80 tracking-widest">NEXT</span>
          <span class="text-xl">≫</span>
        </div>
      </div>
    </div>
  </div>

  <%# --- エラー回避用の隠しフォーム --- %>
  <div class="hidden">
    <%= form_with url: finish_story_path, method: :patch, id: 'finish-form', local: true do %>
    <% end %>
  </div>
</div>

<script>
  (function() {
    // 外側を " 、クラス名を ' で統一しました
    const dialogues = [
      "……驚かせてしまったか。ふふ、いきなり目の前に現れたら<br class='md:hidden'>無理もない。",
      "俺の名は金宵（こよい）。一応、この土地を守る神様<br class='md:hidden'>……だったんだがな。",
      "今は力を失って、こんなちんまりした姿になってしまった。<br class='md:hidden'>……困ったもんだ。",
      "だが、お前の魂を見て<br class='md:hidden'>ピンときたんだ。お前なら、<br class='md:hidden'>俺を助けてくれそうだとな。",
      "お前の散歩に、俺も一緒に<br class='md:hidden'>連れていってくれないか？"
    ];

    let currentIndex = 0;
    let isWaiting = false;

    window.nextDialogue = function() {
      if (isWaiting) return;

      const textElement = document.getElementById("dialogue-text");
      const finishForm = document.getElementById("finish-form");
      
      if (!textElement) return;

      isWaiting = true;

      // 1. フェードアウト
      textElement.style.opacity = 0;

      // 2. 0.2秒後に切り替え
      setTimeout(() => {
        textElement.innerHTML = ""; // 前の文字をクリア
        currentIndex++;

        if (currentIndex < dialogues.length) {
          textElement.innerHTML = dialogues[currentIndex];
          textElement.style.opacity = 1;
          isWaiting = false;
        } else if (currentIndex === dialogues.length) {
          textElement.innerHTML = "……ありがとう。お前の見せる<br class='md:hidden'>景色、楽しみにしているぞ。";
          textElement.style.opacity = 1;
          isWaiting = false;
        } else {
          if (finishForm) finishForm.submit();
        }
      }, 200); 
    };

    document.addEventListener("turbo:load", () => { 
      currentIndex = 0;
      isWaiting = false;
    });
  })();
</script>

<style>
  /* フェード切り替え */
  #dialogue-text { transition: opacity 0.2s ease-in-out; }

  /* NEXTマークの横揺れ */
  @keyframes bounceX {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(5px); }
  }
  .animate-bounce-x { animation: bounceX 0.8s infinite; }

  /* ふわふわ浮遊 */
  @keyframes float {
    0% { transform: translateY(0px); }
    100% { transform: translateY(-12px); }
  }
  .animate-float { animation: float 2.5s ease-in-out infinite alternate; }

  /* 画面全体の登場アニメーション */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fadeIn 1s cubic-bezier(0.22, 1, 0.36, 1); }
</style>