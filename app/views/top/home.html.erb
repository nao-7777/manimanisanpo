<%# 今連れているキャラクターのデータを取得 %>
<% active_char = current_user.user_characters.first %>
<% current_lv = active_char&.level || 1 %>

<%# 進化後（Lv.10以上）かどうかの判定 %>
<% is_v2 = current_lv >= 10 %>

<%# --- スマホ用の数値は一切変えず、md:（PC用）の設定を追加 --- %>
<% koyoi_transform_class = is_v2 ? 
    "w-[250%] max-w-none md:max-w-[800px] -translate-y-[60px] md:top-[10%]" : 
    "w-screen max-w-[500px] md:max-w-[450px] md:top-[15%]" %>

<%# --- 全体 --- %>
<div class="relative min-h-[100dvh] w-full flex flex-col items-center p-6 pb-24 overflow-hidden touch-none">
  
  <%# --- 1. 左上のステータスエリア --- %>
  <div class="absolute top-0 left-0 z-30 pointer-events-none p-0">
    <div class="pointer-events-auto">
      <%= render 'layouts/header' %>
    </div>
  </div>

  <%# --- 2. メインキャラ --- %>
  <div class="absolute top-[20%] left-1/2 -translate-x-1/2 <%= koyoi_transform_class %> h-auto z-0 pointer-events-none flex justify-center transition-all duration-500">
    <div class="relative w-full h-full flex justify-center">
      <%# PCでの見切れを防ぐために、画像自体にも md:max-h だけ追加 %>
      <%= image_tag current_user.current_koyoi_image, class: "w-full h-auto object-contain filter drop-shadow-xl md:max-h-[80vh]" %>
    </div>
  </div>

  <%# --- 3. お散歩ボタン --- %>
  <div style="position: fixed; bottom: 130px; left: 50%; transform: translateX(-50%); width: 100%; max-width: 240px; z-index: 50; pointer-events: auto;">
    <%= link_to new_walking_path, class: "group relative flex items-center justify-center w-full" do %>
      <div class="absolute inset-0 bg-[#F28FA3] rounded-full blur-lg opacity-40 group-active:blur-md transition-all"></div>
      
      <%# ボタン本体 %>
      <div class="relative w-full bg-[#F28FA3] text-white text-2xl font-black py-6 rounded-full shadow-lg border-b-8 border-[#B55D6F] flex items-center justify-center gap-2 transition-transform active:translate-y-1 active:border-b-0">
        <span>お散歩する</span>
      </div>
    <% end %>
  </div>

  <%# 常に空で待機し、ボタンが押された時だけ中身が流し込まれる %>
  <%= turbo_frame_tag "modal", target: "_top" %>
</div>