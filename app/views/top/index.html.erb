<div class="fixed inset-0 w-full h-screen flex flex-col items-center p-6 pt-20 overflow-hidden" 
     style="background: linear-gradient(180deg, #ffe2ea 30%, #97DBC1 90%);">
  
  <%# --- タイトルセクション --- %>
  <div class="flex-shrink-0 py-4 flex flex-col items-center relative z-10">
    <div class="absolute w-48 h-48 bg-white/40 rounded-full blur-3xl -z-10 -top-4"></div>
    <h1 class="flex flex-col items-center select-none">
      <div class="flex gap-1.5 mb-1">
        <span class="text-5xl md:text-7xl font-black text-[#76d7b5] drop-shadow-[4px_4px_0px_white] -rotate-6">ま</span>
        <span class="text-5xl md:text-7xl font-black text-[#76d7b5] drop-shadow-[4px_4px_0px_white] rotate-3 mt-2">に</span>
        <span class="text-5xl md:text-7xl font-black text-[#76d7b5] drop-shadow-[4px_4px_0px_white] -rotate-3">ま</span>
        <span class="text-5xl md:text-7xl font-black text-[#76d7b5] drop-shadow-[4px_4px_0px_white] rotate-6 mt-2">に</span>
      </div>
      <div class="mt-1">
        <span class="text-3xl md:text-5xl font-black text-[#5ec9a7] tracking-[0.3em] pl-[0.3em] drop-shadow-[5px_5px_0px_white]">散歩</span>
      </div>
    </h1>
  </div>

  <%# --- アプリ紹介カード (フォントサイズ微調整版) --- %>
  <div class="w-full max-w-[440px] flex-1 min-h-0 mt-4 mb-4 bg-white/50 backdrop-blur-3xl rounded-[50px] border border-white/80 shadow-[0_20px_50px_rgba(0,0,0,0.1)] flex flex-col overflow-hidden z-10">
    <div class="flex-1 overflow-y-auto p-8 md:p-10 custom-scrollbar">
      
      <%# メインコピー (サイズダウン) %>
      <div class="flex flex-col items-center space-y-4 mb-10 text-center">
        <h2 class="text-2xl md:text-3xl font-black text-[#3d8b83] leading-tight tracking-tight">
          神様と歩く、いつもの道。
        </h2>
        <p class="text-[15px] md:text-[16px] leading-relaxed text-gray-800 font-bold opacity-80">
          力を失い、姿も色も忘れてしまった「小さな土地神様」。あなたの何気ない歩みが、神様の力になります。
        </p>
      </div>

      <%# 遊び方のステップ (サイズダウン) %>
      <%# 遊び方のステップ (歩数を排除し、現在の仕様に準拠) %>
      <div class="space-y-10">
        <div class="flex gap-4">
          <span class="text-[#4db6ac] font-black text-xl mt-1 opacity-50">01</span>
          <div>
            <p class="text-[17px] font-black text-gray-900 mb-1">お散歩して、絆を深める</p>
            <p class="text-[13px] text-gray-700 leading-relaxed font-semibold">
              「お散歩する」ボタンを押して出発。歩いた時間がエネルギーになり、神様に力を与えていきます。
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-[#4db6ac] font-black text-xl mt-1 opacity-50">02</span>
          <div>
            <p class="text-[17px] font-black text-gray-900 mb-1">お題を見つけて、記録する</p>
            <p class="text-[13px] text-gray-700 leading-relaxed font-semibold">
              「赤い花」「大きな橋」など、散歩中に見つけた景色を撮影。神様へ思い出を捧げて、お題をクリアしましょう。
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-[#4db6ac] font-black text-xl mt-1 opacity-50">03</span>
          <div>
            <p class="text-[17px] font-black text-gray-900 mb-1">共に、進化する</p>
            <p class="text-[13px] text-gray-700 leading-relaxed font-semibold">
              絆が深まると神様が進化。真っ白だった図鑑があなたの写真で彩られ、特別な姿へと変わっていきます。
            </p>
          </div>
        </div>
      </div>

      <%# 結び (サイズダウン) %>
      <div class="mt-12 pt-8 border-t-2 border-[#4db6ac]/10 text-center pb-4">
        <p class="text-[15px] font-black text-[#4db6ac] italic tracking-[0.05em]">
          目的地のない散歩は、もう終わり。
        </p>
        <p class="text-[12px] text-gray-600 mt-3 font-bold">
          今日から隣には、あなたを待っている相棒がいます。
        </p>
      </div>
    </div>
  </div>

  <%# --- 下部リンク --- %>
  <div class="flex-shrink-0 w-full pb-4 z-10 text-center">
    <div class="flex gap-6 justify-center text-[11px] text-gray-500 font-bold mb-1">
      <%= link_to '利用規約', terms_path, class: 'hover:text-[#4db6ac] cursor-pointer transition-colors decoration-[#4db6ac] hover:underline underline-offset-4' %>
      <%= link_to 'プライバシーポリシー', privacy_path, class: 'hover:text-[#4db6ac] cursor-pointer transition-colors decoration-[#4db6ac] hover:underline underline-offset-4' %>
    </div>
    <p class="text-[10px] text-gray-400 font-medium italic tracking-[0.15em]">Everyday is an Adventure</p>
  </div>
</div>