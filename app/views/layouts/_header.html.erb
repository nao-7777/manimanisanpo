<div class="flex flex-col gap-3 p-6 font-sans select-none">
  <div class="flex items-center gap-3">
    <%# --- LEVELの丸（実データ連動 + ぷっくり加工） --- %>
    <div class="w-16 h-16 bg-[#65C7A4] text-white flex flex-col items-center justify-center rounded-full shadow-sm p-4 border-b-4 border-[#54a88a] shrink-0 relative overflow-hidden">
      <%# 左上に光の筋を入れて、おもちゃのような質感に %>
      <div class="absolute top-1 left-2 w-8 h-4 bg-white/20 rounded-full blur-[1px] -rotate-15"></div>
      
      <span class="text-[9px] font-black leading-none mb-0.5 tracking-tighter opacity-90">LEVEL</span>
      <span class="text-3xl font-black leading-none drop-shadow-sm">
        <%= current_user.level %>
      </span>
    </div>
    
    <%# --- キャラクターの名前 --- %>
    <div class="mb-1">
      <span class="text-[#4C6496] font-black text-xl tracking-tighter italic">
        <%# 💡 ここを「キャラの名前」に変更（カラム名に合わせて調整してください） %>
        <%= current_user.fox_image_name || "フォックス" %> 
      </span>
    </div>
  </div>
  
  <%# --- 経験値バー --- %>
  <div class="relative -mt-1">
    <%# 進行度の計算 %>
    <% current_limit = current_user.required_exp_for_next_level %>
    <% percent = (current_user.exp.to_f / current_limit * 100).clamp(0, 100) %>

    <div class="w-50 h-3.5 bg-white/60 rounded-full overflow-hidden border-2 border-white shadow-sm relative">
      <%# 💡 数値テキストは削除し、バーの伸びだけを表示 %>
      <div class="bg-gradient-to-r from-[#65C7A4] to-[#AEEAD3] h-full rounded-full shadow-inner transition-all duration-500" 
           style="width: <%= percent %>%;">
      </div>
    </div>
  </div>

  <%# --- 親愛度（デザイン維持） --- %>
  <div class="relative mt-0.5">
    <div class="bg-white/95 backdrop-blur-md px-5 py-2 rounded-full shadow-md border border-white w-fit flex items-center gap-2">
      <span class="text-[#F18499] text-sm font-black">親愛度</span>
      <span class="text-[#F18499] text-sm tracking-[0.2em] font-bold">★☆☆☆☆</span>
    </div>
  </div>
</div>