<%# layouts/_header.html.erb %>
<div class="flex flex-col gap-3 p-6 font-sans">
  <div class="flex items-center gap-3">
    <%# LEVELの丸 %>
    <div class="w-16 h-16 bg-[#65C7A4] text-white flex flex-col items-center justify-center rounded-full shadow-sm p-4 border-b-4 border-[#54a88a] shrink-0">
      <span class="text-[9px] font-black leading-none mb-0.5 tracking-tighter opacity-90">LEVEL</span>
      <span class="text-3xl font-black leading-none">1</span>
    </div>
    
    <%# 名前：お散歩モードに合わせた極太(font-black)と色 %>
    <div class="mb-1">
      <span class="text-[#4C6496] font-black text-xl tracking-tighter">キャラの名前</span>
    </div>
  </div>
  
  <%# 経験値バー %>
  <div class="relative -mt-1">
    <div class="w-50 h-3.5 bg-white/60 rounded-full overflow-hidden border-2 border-white shadow-sm">
      <div class="bg-gradient-to-r from-[#65C7A4] to-[#AEEAD3] h-full w-[40%] rounded-full shadow-inner"></div>
    </div>
  </div>

  <%# 親愛度：お散歩モードに合わせたピンク色 %>
  <div class="relative mt-0.5">
    <div class="bg-white/95 backdrop-blur-md px-5 py-2 rounded-full shadow-md border border-white w-fit flex items-center gap-2">
      <span class="text-[#F18499] text-sm font-black">親愛度</span>
      <span class="text-[#F18499] text-sm tracking-[0.2em] font-bold">★☆☆☆☆</span>
    </div>
  </div>
</div>