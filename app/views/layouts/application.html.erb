<!DOCTYPE html>
<html lang="ja" class="h-[100svh] overflow-hidden">
  <head>
    <%= display_meta_tags(default_meta_tags) %>
    <meta name="apple-mobile-web-app-title" content="まにまに散歩">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%# 2. status-bar を default に。これでブラウザと同じ「上に時計等がある」普通の見た目になります %>
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#F5F5F0">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# 外部ライブラリ %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    
    <style>
      html, body {
        height: 100svh;
        overflow: hidden;
        margin: 0;
        padding: 0;
        background-color: #F5F5F0;
      }
      /* スクロールが必要なページは main の中で完結させる */
      main {
        height: 100%;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
      }
    </style>
  </head>

  <body class="w-full flex flex-col bg-transparent">

    <%# --- 背景レイヤー（ここも inset-0 ではなく 100% 指定で「箱」の中に収める） --- %>
    <div class="fixed top-0 left-0 w-full h-full -z-20" style="background: linear-gradient(to bottom, #F5F5F0 0%, #F5F5F0 35%, #A4D5BD 100%);"></div>
    <div class="fixed top-0 left-0 w-full h-full -z-10 opacity-40 pointer-events-none" style="background-image: url('<%= asset_path('asanoha.png') %>'); background-size: 650px auto;"></div>

    <%# --- ログイン前共通ヘッダー（余計な env(...) は排除） --- %>
    <% unless user_signed_in? || content_for?(:no_nav) %>
      <header class="fixed top-0 left-0 w-full flex justify-between items-center p-6 z-50 bg-transparent">
        <%= link_to root_path, class: "transition-transform hover:scale-105 active:scale-95" do %> 
          <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center shadow-md overflow-hidden">
            <%= image_tag "logomark.png", class: "w-full h-full object-contain" %>
          </div>
        <% end %>
        <%= link_to "ログイン", new_user_session_path, class: "px-6 py-2.5 text-white font-bold text-lg rounded-full shadow-md", style: "background-color: #65C7A4;" %>
      </header>
    <% end %>

    <%# メインコンテンツ %>
    <main class="relative z-10 flex-1">
      <%= yield %>
    </main>

    <%# ボトムナビゲーション %>
    <% if user_signed_in? && !content_for?(:no_nav) %>
      <div class="z-50">
        <%= render 'layouts/bottom_nav' %>
      </div>
    <% end %>

    <%= turbo_frame_tag "modal" %>
  </body>
</html>