<!DOCTYPE html>
<html lang="ja" style="height: 100%; margin: 0; padding: 0; overflow: hidden;">
  <head>
    <title>ManimaniSanpo</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/@hotwired/turbo@7.3.0/dist/turbo.es2017-umd.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  </head>

  <%# --- body 自体にグラデを塗ることで「隙間」を完全に殺す --- %>
  <body style="margin: 0; padding: 0; overflow: hidden; width: 100%; height: 100%; position: fixed; touch-action: none;
               background: linear-gradient(to bottom, #F5F5F0 0%, #F5F5F0 35%, #A4D5BD 100%) no-repeat;
               background-size: 100% 100%;">

    <%# --- 麻の葉レイヤー：以前の「薄さ」を再現するために opacity を 0.08 に設定 --- %>
    <%# position: fixed で top: -50px にすることで、iPhoneのバーの隙間も埋めます %>
    <div style="position: fixed; top: -50px; left: 0; width: 100vw; height: calc(100vh + 100px); z-index: 0; pointer-events: none;
                background-image: url('<%= asset_path('asanoha.png') %>');
                background-size: 650px auto;
                background-repeat: repeat;
                opacity: 0.08;
                image-rendering: -webkit-optimize-contrast;">
    </div>

    <%# --- ヘッダー --- %>
    <% unless content_for?(:no_nav) %>
      <% unless user_signed_in? %>
        <header class="fixed top-0 left-0 w-full flex justify-between items-center p-6 z-50 bg-transparent">
          <%= link_to root_path, class: "transition-transform hover:scale-105 active:scale-95" do %> 
            <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center shadow-md overflow-hidden">
              <%= image_tag "logomark.png", class: "w-full h-full object-contain" %>
            </div>
          <% end %>
          <%= link_to "ログイン", new_user_session_path, 
              class: "px-6 py-2.5 text-white font-bold text-lg rounded-full shadow-md inline-block text-center",
              style: "background-color: #65C7A4;" %>
        </header>
      <% end %>
    <% end %>

    <%# メインコンテンツ %>
    <main style="position: relative; z-index: 1; height: 100%; width: 100%;">
      <%= yield %>
    </main>

    <% if user_signed_in? && !content_for?(:no_nav) %>
      <%= render 'layouts/bottom_nav' %>
    <% end %>

    <%= turbo_frame_tag "modal" %>
  </body>
</html>